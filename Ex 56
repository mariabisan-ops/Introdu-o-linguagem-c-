#include <stdio.h>

int main (){
    float n1, n2, op;
    printf ("digite o primeiro valor:\n");
    scanf ("%f", &n1);
    printf ("digite o segundo valor:\n");
    scanf ("%f", &n2);
    printf ("qual operacao desejada?\n1.Adicao\n2.Subtracao\n3.Divisao\n4.Multiplicao\n");
    scanf ("%f", &op);
    if (op == 1){
       printf ("resultado: %.2f\n", n1+n2);
    }
    else {
       if ( op == 2){
             printf ("resultado: %.2f\n", n1-n2);
       }
       else {
          if (op == 3{
              printf ("resultado: %.2f\n", n1/n2);
          }
          else {
              printf ("resultado: %.2f\n", n1*n2);
          }
       }
    }
}
